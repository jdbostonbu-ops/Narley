{
  "expo": {
    "name": "provider",
    "slug": "provider",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/narley-icon-1024.png",
    "scheme": "provider",
    "userInterfaceStyle": "automatic",
    "android": {
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/narley-icon-1024.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "image": "./assets/narley-logo.png",
          "imageWidth": 224
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
