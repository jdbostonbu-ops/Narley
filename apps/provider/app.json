{
  "expo": {
    "name": "provider",
    "slug": "provider",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/narley-icon-1024.png",
    "scheme": "provider",
    "userInterfaceStyle": "automatic",
    "android": {
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/narley-icon-1024.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "image": "./assets/narley-logo.png",
          "imageWidth": 224
        }
      ],
      "expo-font",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Narley to use your location to show nearby weather alerts."
        }
      ]
    ],
    "experiments": {
      "reactCompiler": true
    },
    "ios": {
      "bundleIdentifier": "com.jacqnexpo.provider"
    }
  }
}
